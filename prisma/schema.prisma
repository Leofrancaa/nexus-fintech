generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      Int                   @id @default(autoincrement())
  nome                    String
  email                   String                @unique
  senha                   String?
  currency                String                @default("BRL")
  accepted_terms          Boolean               @default(false)
  accepted_terms_at       DateTime?
  reset_password_token    String?
  reset_password_expires  DateTime?
  created_at              DateTime              @default(now())
  updated_at              DateTime              @default(now()) @updatedAt

  categories              Category[]
  expenses                Expense[]
  incomes                 Income[]
  cards                   Card[]
  card_invoices_payments  CardInvoicePayment[]
  goals                   Goal[]
  plans                   Plan[]
  plan_contributions      PlanContribution[]
  thresholds              Threshold[]
  invite_codes_created    InviteCode[]          @relation("InviteCodeCreatedBy")
  invite_codes_used       InviteCode[]          @relation("InviteCodeUsedBy")

  @@map("users")
}

model Category {
  id         Int        @id @default(autoincrement())
  nome       String
  cor        String     @default("#6B7280")
  tipo       String
  parent_id  Int?
  user_id    Int
  created_at DateTime   @default(now())
  updated_at DateTime   @default(now()) @updatedAt

  user       User       @relation(fields: [user_id], references: [id])
  parent     Category?  @relation("CategoryParent", fields: [parent_id], references: [id])
  children   Category[] @relation("CategoryParent")
  expenses   Expense[]
  incomes    Income[]
  thresholds Threshold[]

  @@map("categories")
}

model Expense {
  id                 Int       @id @default(autoincrement())
  metodo_pagamento   String
  tipo               String
  quantidade         Decimal   @db.Decimal(12, 2)
  fixo               Boolean   @default(false)
  data               DateTime  @db.Date
  parcelas           Int?
  frequencia         String?
  user_id            Int
  card_id            Int?
  category_id        Int?
  observacoes        String?
  competencia_mes    Int?
  competencia_ano    Int?
  created_at         DateTime  @default(now())
  updated_at         DateTime  @default(now()) @updatedAt

  user               User      @relation(fields: [user_id], references: [id])
  card               Card?     @relation(fields: [card_id], references: [id])
  category           Category? @relation(fields: [category_id], references: [id])

  @@map("expenses")
}

model Income {
  id          Int       @id @default(autoincrement())
  tipo        String
  quantidade  Decimal   @db.Decimal(12, 2)
  nota        String?
  data        DateTime  @db.Date
  fonte       String?
  fixo        Boolean   @default(false)
  user_id     Int
  category_id Int?
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now()) @updatedAt

  user        User      @relation(fields: [user_id], references: [id])
  category    Category? @relation(fields: [category_id], references: [id])

  @@map("incomes")
}

model Card {
  id                    Int                   @id @default(autoincrement())
  nome                  String
  tipo                  String
  numero                String
  cor                   String                @default("#6B7280")
  limite                Decimal               @default(0) @db.Decimal(12, 2)
  limite_disponivel     Decimal               @default(0) @db.Decimal(12, 2)
  dia_vencimento        Int                   @default(1)
  dias_fechamento_antes Int                   @default(10)
  user_id               Int
  created_at            DateTime              @default(now())
  updated_at            DateTime              @default(now()) @updatedAt

  user                  User                  @relation(fields: [user_id], references: [id])
  expenses              Expense[]
  card_invoices_payments CardInvoicePayment[]

  @@map("cards")
}

model CardInvoicePayment {
  id               Int      @id @default(autoincrement())
  user_id          Int
  card_id          Int
  competencia_mes  Int
  competencia_ano  Int
  amount_paid      Decimal  @db.Decimal(12, 2)
  created_at       DateTime @default(now())

  user             User     @relation(fields: [user_id], references: [id])
  card             Card     @relation(fields: [card_id], references: [id])

  @@unique([user_id, card_id, competencia_mes, competencia_ano])
  @@map("card_invoices_payments")
}

model Goal {
  id          Int      @id @default(autoincrement())
  user_id     Int
  nome        String
  valor_alvo  Decimal  @db.Decimal(12, 2)
  mes         Int
  ano         Int
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  user        User     @relation(fields: [user_id], references: [id])

  @@unique([user_id, mes, ano])
  @@map("goals")
}

model Plan {
  id                Int                @id @default(autoincrement())
  user_id           Int
  nome              String
  descricao         String?
  meta              Decimal            @db.Decimal(12, 2)
  prazo             DateTime           @db.Date
  status            String             @default("Iniciando")
  total_contribuido Decimal            @default(0) @db.Decimal(12, 2)
  created_at        DateTime           @default(now())
  updated_at        DateTime           @default(now()) @updatedAt

  user              User               @relation(fields: [user_id], references: [id])
  contributions     PlanContribution[]

  @@map("plans")
}

model PlanContribution {
  id         Int      @id @default(autoincrement())
  plan_id    Int
  user_id    Int
  valor      Decimal  @db.Decimal(12, 2)
  created_at DateTime @default(now())

  plan       Plan     @relation(fields: [plan_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])

  @@map("plan_contributions")
}

model Threshold {
  id          Int      @id @default(autoincrement())
  user_id     Int
  category_id Int
  valor       Decimal  @db.Decimal(12, 2)
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt

  user        User     @relation(fields: [user_id], references: [id])
  category    Category @relation(fields: [category_id], references: [id])

  @@unique([user_id, category_id])
  @@map("thresholds")
}

model InviteCode {
  id         Int       @id @default(autoincrement())
  code       String    @unique
  created_by Int
  is_used    Boolean   @default(false)
  expires_at DateTime?
  used_by    Int?
  used_at    DateTime?
  created_at DateTime  @default(now())

  creator    User      @relation("InviteCodeCreatedBy", fields: [created_by], references: [id])
  user       User?     @relation("InviteCodeUsedBy", fields: [used_by], references: [id])

  @@map("invite_codes")
}
